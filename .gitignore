# =============================================================================
# USDA Agricultural Data Analysis - .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python (pipeline/)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyc
*.pyo
*.pyd
venv/
.venv/
env/
ENV/

# -----------------------------------------------------------------------------
# Node.js (web_app/)
# -----------------------------------------------------------------------------
node_modules/
.next/
out/
web_app/node_modules/
web_app/.next/
web_app/out/

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# OS Generated Files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Environment Variables
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
secrets.txt

# -----------------------------------------------------------------------------
# Data Files (large/generated - live on S3)
# -----------------------------------------------------------------------------
survey_datasets/
census_datasets/
*.parquet
!web_app/public/data/**
UI/

# Backup files
*.bak
*.backup
*.tmp
*.temp

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/

# -----------------------------------------------------------------------------
# Secrets / Keys
# -----------------------------------------------------------------------------
*.pem
*.key

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
.cache/
tmpclaude-*
